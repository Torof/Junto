# Supabase — client-safe (anon key, protected by RLS)
# NEVER put service_role key here — see SECURITY.md
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Mapbox
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Google Places
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=

# Sentry — DSN is public and baked into the bundle. Project must have
# "Allowed Domains" restricted to com.junto.app in Sentry settings.
EXPO_PUBLIC_SENTRY_DSN=

# Sentry auth token — build-time only, used for source map upload.
# MUST be a project-scoped token with scopes: project:releases, project:read.
# Store as an EAS secret (eas secret:create), never commit to .env.
# SENTRY_AUTH_TOKEN=
